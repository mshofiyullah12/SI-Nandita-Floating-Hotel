rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // LPK data rules
    match /lpk_data/main {
      allow read, write: if isSignedIn();
    }

    // Sessions rules
    match /sessions/{username} {
      allow read, write: if isSignedIn();
    }
  }
}
